<Page
  x:Class="GalleryUI.Views.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:GalleryUI.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="设置"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="42">
      <ui:TextBlock
        Margin="0,0,0,8"
        FontTypography="BodyStrong"
        Text="外观与行为" />
      <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon Color24}">
        <ui:CardControl.Header>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ui:TextBlock
              Grid.Row="0"
              FontTypography="Body"
              Text="应用主题" />
            <ui:TextBlock
              Grid.Row="1"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="选择要显示的应用主题" />
          </Grid>
        </ui:CardControl.Header>
        <ComboBox
          x:Name="ThemeComboBox"
          Grid.Column="1"
          MinWidth="200"
          SelectionChanged="OnThemeComboBoxSelectionChanged">
          <ComboBoxItem Content="浅色" />
          <ComboBoxItem Content="深色" />
        </ComboBox>
      </ui:CardControl>

      <ui:TextBlock
        Margin="0,24,0,8"
        FontTypography="BodyStrong"
        Text="下载设置" />
      <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon Folder24}">
        <ui:CardControl.Header>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ui:TextBlock
              Grid.Row="0"
              FontTypography="Body"
              Text="下载路径" />
            <ui:TextBlock
              Grid.Row="1"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="设置漫画下载保存的目录" />
          </Grid>
        </ui:CardControl.Header>
        <Grid MinWidth="400">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox
            x:Name="DownloadPathTextBox"
            Grid.Column="0"
            Height="32"
            Margin="0,0,8,0"
            Padding="8,0"
            VerticalContentAlignment="Center"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            IsReadOnly="True"
            Text="{Binding DownloadPath, Mode=OneWay}" />
          <ui:Button
            Grid.Column="1"
            Click="OnBrowseDownloadPathClick"
            Content="浏览" />
        </Grid>
      </ui:CardControl>

      <ui:TextBlock
        Margin="0,24,0,8"
        FontTypography="BodyStrong"
        Text="下载环境" />
      <ui:CardExpander
        x:Name="GalleryDlCard"
        Margin="0,0,0,12"
        Icon="{ui:SymbolIcon Toolbox24}">
        <ui:CardExpander.Header>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
              Grid.Row="0"
              Grid.Column="0"
              FontTypography="Body"
              Text="gallery-dl" />
            <ui:TextBlock
              Grid.Row="1"
              Grid.Column="0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="检查 gallery-dl 依赖环境" />
            <Border
              x:Name="GalleryDlStatusBorder"
              Grid.Row="0"
              Grid.RowSpan="2"
              Grid.Column="1"
              Margin="0,0,16,0"
              Padding="12,4"
              VerticalAlignment="Center"
              Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
              BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Visibility="Collapsed">
              <TextBlock
                x:Name="GalleryDlStatusTextBlock"
                FontSize="12"
                Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
            </Border>
          </Grid>
        </ui:CardExpander.Header>
        <StackPanel Margin="16">
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
              Grid.Column="0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="状态" />
            <ui:TextBlock
              x:Name="GalleryDlStatusText"
              Grid.Column="1" />
          </Grid>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
              Grid.Column="0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="版本" />
            <ui:TextBlock
              x:Name="GalleryDlVersionText"
              Grid.Column="1"
              Text="-" />
          </Grid>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
              Grid.Column="0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="路径" />
            <ui:TextBlock
              x:Name="GalleryDlPathText"
              Grid.Column="1"
              Text="-"
              TextWrapping="Wrap" />
          </Grid>
          <ui:InfoBar
            x:Name="GalleryDlInfoBar"
            Margin="0,12,0,0"
            IsOpen="False"
            Severity="Error"
            Title="环境缺失"
            Message="未找到 gallery-dl.exe，可自行下载并将其放置到应用程序目录下并重启应用" />
        </StackPanel>
      </ui:CardExpander>

      <ui:TextBlock
        Margin="0,24,0,8"
        FontTypography="BodyStrong"
        Text="关于" />
      <ui:CardExpander ContentPadding="0" Icon="{ui:SymbolIcon Info24}">
        <ui:CardExpander.Header>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock
              Grid.Row="0"
              Grid.Column="0"
              FontTypography="Body"
              Text="Gallery UI" />
            <ui:TextBlock
              Grid.Row="1"
              Grid.Column="0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="基于 WPF UI 构建的gallery-dl可视化下载工具" />
            <TextBlock
              Grid.Row="0"
              Grid.RowSpan="2"
              Grid.Column="1"
              Margin="0,0,16,0"
              VerticalAlignment="Center"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{Binding AppVersion, Mode=OneWay}" />
          </Grid>
        </ui:CardExpander.Header>
        <StackPanel>
          <ui:Anchor
            Margin="0"
            Padding="16"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            CornerRadius="0"
            NavigateUri="https://github.com/mikf/gallery-dl">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="gallery-dl 官方文档" />
              <ui:SymbolIcon Grid.Column="1" Symbol="Link24" />
            </Grid>
          </ui:Anchor>
        </StackPanel>
      </ui:CardExpander>
    </StackPanel>
  </ScrollViewer>
</Page>
